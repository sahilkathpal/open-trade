# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Dhan broker (single-user / dev mode) ──────────────────────────────────────
# In multi-tenant mode, each user stores credentials in Firestore via the UI.
# These env vars are the fallback for local development.
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
DHAN_SANDBOX=false

# ── Agent behaviour ────────────────────────────────────────────────────────────
AUTONOMOUS=false
SEED_CAPITAL=10000

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=        # single-user mode: your chat ID
TELEGRAM_BOT_USERNAME=   # e.g. MyTradingBot (without @) — needed for deep links

# ── Firebase (multi-tenant) ───────────────────────────────────────────────────
# Paste the entire service account JSON as a single-line string.
FIREBASE_SERVICE_ACCOUNT_KEY=

# ── Next.js frontend ──────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
